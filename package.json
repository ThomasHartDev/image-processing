{
  "name": "@thomashartdev/image-processing",
  "version": "0.3.0",
  "description": "Sharp-based image optimizer with SSIM-driven quality search and perceptual scoring. Used by pixel-wand and atlas.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ThomasHartDev/pixel-wand.git",
    "directory": "packages/image-processing"
  },
  "keywords": [
    "image",
    "optimization",
    "sharp",
    "ssim",
    "perceptual"
  ],
  "type": "commonjs",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "smoke": "pnpm build && node scripts/smoke.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepare": "pnpm build"
  },
  "dependencies": {
    "sharp": "^0.34.5",
    "ssim.js": "^3.5.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "typescript": "^5",
    "vitest": "^3.2.4"
  }
}
